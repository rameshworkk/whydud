# Backend environment variables for local development
# Copy to .env and load with python-decouple or export manually

DJANGO_SECRET_KEY=dev-secret-key-not-for-production
DJANGO_SETTINGS_MODULE=whydud.settings.dev

POSTGRES_DB=whydud
POSTGRES_USER=whydud
POSTGRES_PASSWORD=whydud
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0

MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_MASTER_KEY=masterKey

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
EMAIL_ENCRYPTION_KEY=
OAUTH_ENCRYPTION_KEY=

CLOUDFLARE_EMAIL_WEBHOOK_SECRET=dev-webhook-secret

RESEND_API_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

FRONTEND_URL=http://localhost:3000

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Sentry error monitoring (optional — leave empty to disable)
SENTRY_DSN=https://c99f9072cdfaa93d364a6e7b4906fd25@o4510986847977472.ingest.us.sentry.io/4510986850992128

# Proxy rotation for scraping (comma-separated, optional)
# Format: http://user:pass@host:port,http://host2:port2
SCRAPING_PROXY_LIST=
# Ban cooldown tuning (seconds)
SCRAPING_PROXY_BAN_COOLDOWN_BASE=30
SCRAPING_PROXY_BAN_MAX_COOLDOWN=600
