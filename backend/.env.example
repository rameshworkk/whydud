# Backend environment variables for local development
# Copy to .env and load with python-decouple or export manually

DJANGO_SECRET_KEY=dev-secret-key-not-for-production
DJANGO_SETTINGS_MODULE=whydud.settings.dev

POSTGRES_DB=whydud
POSTGRES_USER=whydud
POSTGRES_PASSWORD=whydud
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0

MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_MASTER_KEY=masterKey

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
EMAIL_ENCRYPTION_KEY=
OAUTH_ENCRYPTION_KEY=

CLOUDFLARE_EMAIL_WEBHOOK_SECRET=dev-webhook-secret

RESEND_API_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

FRONTEND_URL=http://localhost:3000

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
