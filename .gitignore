# ============================================================
# Whydud — .gitignore
# ============================================================

# ---- Secrets ----
.env
.env.local
.env.*.local
docker/.env

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.installed.cfg
*.egg
.venv/
venv/
env/
pip-log.txt

# ---- Django ----
backend/staticfiles/
backend/media/
backend/*.log
*.log

# ---- Node / Next.js ----
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.env*
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*

# ---- Docker ----
docker/caddy_data/

# ---- IDEs ----
.vscode/settings.json
.idea/
*.swp
*.swo

# ---- OS ----
.DS_Store
Thumbs.db

# ---- Scrapy ----
backend/.scrapy/

# ---- Pytest ----
.pytest_cache/
.coverage
htmlcov/
