# ============================================================
# Whydud — Environment Variables
# Copy to .env and fill in all values before starting.
# NEVER commit .env to git.
# ============================================================

# ---- Django ----
DJANGO_SECRET_KEY=change-me-generate-with-python-secrets
DJANGO_SETTINGS_MODULE=whydud.settings.prod

# ---- PostgreS` QL ----
POSTGRES_DB=whydud
POSTGRES_USER=whydud
POSTGRES_PASSWORD=change-me-strong-password

# ---- Redis ----
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0

# ---- Meilisearch ----
MEILISEARCH_MASTER_KEY=change-me-32-char-minimum

# ---- Encryption (AES-256-GCM — generate with: python -c "import secrets; print(secrets.token_hex(32))")
EMAIL_ENCRYPTION_KEY=
OAUTH_ENCRYPTION_KEY=

# ---- Cloudflare Email Worker ----
CLOUDFLARE_EMAIL_WEBHOOK_SECRET=

# ---- Resend (transactional email) ----
RESEND_API_KEY=re_xxxx

# ---- Razorpay (payments) ----
RAZORPAY_KEY_ID=rzp_live_xxx
RAZORPAY_KEY_SECRET=

# ---- Frontend ----
FRONTEND_URL=https://whydud.com
NEXT_PUBLIC_API_URL=https://whydud.com
NEXT_PUBLIC_SITE_URL=https://whydud.com

# ---- Google OAuth ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
