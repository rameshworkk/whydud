# Whydud — Caddy reverse proxy config
# Auto-SSL via Let's Encrypt

whydud.com, www.whydud.com {
    # Django backend: API + admin + webhooks + OAuth
    handle /api/* {
        reverse_proxy backend:8000
    }

    handle /admin/* {
        reverse_proxy backend:8000
    }

    handle /webhooks/* {
        reverse_proxy backend:8000
    }

    # AllAuth OAuth flows (Google login/callback)
    handle /accounts/* {
        reverse_proxy backend:8000
    }

    # OAuth completion redirect (creates one-time code → frontend callback)
    handle /oauth/* {
        reverse_proxy backend:8000
    }

    handle /static/* {
        root * /srv/static
        file_server
    }

    # Flower: Celery monitoring dashboard (basic-auth handled by Flower)
    handle /flower/* {
        reverse_proxy flower:5555
    }

    # Next.js frontend: everything else
    handle {
        reverse_proxy frontend:3000
    }

    # Security headers
    header {
        X-Frame-Options DENY
        X-Content-Type-Options nosniff
        Referrer-Policy strict-origin-when-cross-origin
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
        -Server
    }

    # Logging
    log {
        output file /var/log/caddy/whydud.log
        format json
    }
}

# ---------------------------------------------------------------------------
# URL Prefix Feature: whydud.{marketplace-domain}
#
# Users prepend "whydud." to any shopping URL to research a product.
# Example: whydud.amazon.in/dp/B0CZLQT2GG
#        → 302 redirect to whydud.com/lookup?url=https://amazon.in/dp/B0CZLQT2GG
#
# DNS requirement: Add a wildcard CNAME *.whydud.com → whydud.com
# or individual CNAME records per marketplace domain listed below.
# Caddy will auto-provision TLS for each via Let's Encrypt.
# ---------------------------------------------------------------------------

whydud.amazon.in {
    redir https://whydud.com/lookup?url=https://amazon.in{uri} 302
}

