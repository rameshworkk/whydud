# ============================================================
# Whydud Worker Node — Environment Variables
#
# Copy this file and fill in real values:
#   cp .env.worker.example .env.worker
#
# All services connect to PRIMARY via WireGuard (10.0.0.x)
# ============================================================

# ── Connection to primary (via WireGuard) ───────────────────
WG_PRIMARY_IP=10.0.0.1
POSTGRES_HOST=10.0.0.1
POSTGRES_DB=whydud
POSTGRES_USER=whydud
POSTGRES_PASSWORD=CHANGE_ME

REDIS_URL=redis://:CHANGE_ME@10.0.0.1:6379/0
CELERY_BROKER_URL=redis://:CHANGE_ME@10.0.0.1:6379/0

# ── Django ──────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=whydud.settings.prod
DJANGO_SECRET_KEY=CHANGE_ME

# ── Services ────────────────────────────────────────────────
MEILISEARCH_URL=http://10.0.0.1:7700
MEILISEARCH_MASTER_KEY=CHANGE_ME

# ── Encryption keys ────────────────────────────────────────
EMAIL_ENCRYPTION_KEY=CHANGE_ME
OAUTH_ENCRYPTION_KEY=CHANGE_ME

# ── Worker identity (MUST be unique per worker) ────────────
# Examples: oci-w1, oci-w2, ctb-w1, ctb-w2
CELERY_WORKER_ID=CHANGE_ME

# ── Proxy (optional — only for enrichment/scraping) ────────
SCRAPING_PROXY_LIST=
SCRAPING_PROXY_TYPE=rotating
