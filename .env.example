# ============================================================
# Whydud — Production Environment Variables
# Copy to /opt/whydud/.env on each server and fill in real values
# ============================================================

# ---- Django ----
DJANGO_SECRET_KEY=CHANGE_ME_generate_with_python_c_import_secrets_secrets_token_urlsafe_64
DJANGO_SETTINGS_MODULE=whydud.settings.prod
DJANGO_ALLOWED_HOSTS=whydud.com,www.whydud.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://whydud.com,https://www.whydud.com

# ---- PostgreSQL ----
POSTGRES_DB=whydud
POSTGRES_USER=whydud
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# Replication user password (PRIMARY node only — used by init-replication.sh)
REPLICATOR_PASSWORD=CHANGE_ME_replicator_password

# ---- Redis ----
REDIS_PASSWORD=CHANGE_ME_redis_password

# ---- Meilisearch ----
MEILISEARCH_MASTER_KEY=CHANGE_ME_meili_master_key

# ---- Encryption ----
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
EMAIL_ENCRYPTION_KEY=CHANGE_ME
OAUTH_ENCRYPTION_KEY=CHANGE_ME

# ---- Frontend ----
NEXT_PUBLIC_API_URL=https://whydud.com
NEXT_PUBLIC_SITE_URL=https://whydud.com

# ---- Google OAuth (optional — leave empty to disable) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Resend (transactional email) ----
RESEND_API_KEY=

# ---- Cloudflare Email Worker ----
CLOUDFLARE_EMAIL_WEBHOOK_SECRET=

# ---- Razorpay (payments) ----
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ---- Sentry (error monitoring — optional) ----
SENTRY_DSN=

# ---- Scraping (REPLICA node only) ----
# SCRAPING_PROXY_LIST=http://user:pass@gw.dataimpulse.com:823
# SCRAPING_PROXY_TYPE=rotating
